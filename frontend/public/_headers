# Cloudflare Pages headers — fixes the "stale index.html references missing
# CSS hash" problem that produces a "MIME type ('text/html') is not a
# supported stylesheet" error after a deploy.
#
# Strategy: hashed assets are immutable for a year; the HTML shell is never
# cached so the browser always fetches the fresh asset filenames.

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Hashed JS/CSS/images bundled by Vite — filenames change on every build,
# so we can safely keep them forever in the browser cache.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static files in /public that don't get hashed — short cache so updates
# show up within an hour.
/favicon.svg
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/og-default.jpg
  Cache-Control: public, max-age=3600
